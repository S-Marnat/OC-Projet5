@model ExpressVoitures.Models.Finition

@{
    ViewData["Title"] = "Détails de la finition";
}

<h1>Détails de la finition</h1>

<div>
    <dl class="row">
        <dt class="col-sm-2">
            Nom de la finition
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Nom)
        </dd>
        <dt class="col-sm-2">
            Modèle correspondant à cette finition
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Modele.Nom)
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id">Editer la finition</a> |
    <a asp-action="Index">Retour à la liste des finitions</a>
</div>
