@model ExpressVoitures.Models.Finition

@{
    ViewData["Title"] = "Créer une finition";
}

<h1>Créer une finition</h1>

<div class="row formDonnees">
    <div class="col-md-5 mx-auto">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger" aria-live="polite"></div>
            <div class="form-group">
                <label asp-for="Nom" class="control-label">Nom de la finition</label>
                <input asp-for="Nom" class="form-control" required />
                <span asp-validation-for="Nom" class="text-danger" aria-live="polite"></span>
            </div>
            <div class="form-group">
                <label asp-for="IdModele" class="control-label">Modèle correspondant à cette finition</label>
                <select asp-for="IdModele" class="form-control" asp-items="ViewBag.IdModele" required></select>
                <span asp-validation-for="IdModele" class="text-danger" aria-live="polite"></span>
            </div>
            <div class="form-group d-flex justify-content-center">
                <input type="submit" value="Create" class="boutonAction" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Retour à la liste des finitions</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
