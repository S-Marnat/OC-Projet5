@model ExpressVoitures.Models.Finition

@{
    ViewData["Title"] = "Supprimer une finition";
}

<h1>Supprimer une finition</h1>

<h2>Êtes-vous sûr de vouloir supprimer cette finition ?</h2>
<div>
    <dl class="row">
        <dt class="col-sm-2">
            Nom de la finition
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Nom)
        </dd>
        <dt class="col-sm-2">
            Modèle correspondant à cette finition
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Modele.Nom)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Supprimer" class="boutonAction d-flex justify-content-center" /> |
        <a asp-action="Index">Retour à la liste des finitions</a>
    </form>
</div>
