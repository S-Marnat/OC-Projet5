@model ExpressVoitures.Models.Voiture

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Voiture</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <div class="form-group">
                <label asp-for="CodeVin" class="control-label"></label>
                <input asp-for="CodeVin" class="form-control" />
                <span asp-validation-for="CodeVin" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Annee" class="control-label"></label>
                <select asp-for="Annee" asp-items="ViewBag.Annees" class="form-control">
                    <option value="">Sélectionnez une année</option>
                </select>
                <span asp-validation-for="Annee" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="TelechargerImage" class="control-label"></label>
                <input asp-for="TelechargerImage" class="form-control" type="file" />
                <span asp-validation-for="TelechargerImage" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Description" class="control-label"></label>
                <input asp-for="Description" class="form-control" />
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="DateAchat" class="control-label"></label>
                <input asp-for="DateAchat" class="form-control" />
                <span asp-validation-for="DateAchat" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="PrixAchat" class="control-label"></label>
                <input asp-for="PrixAchat" class="form-control" />
                <span asp-validation-for="PrixAchat" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="VoitureReparee" /> @Html.DisplayNameFor(model => model.VoitureReparee)
                </label>
            </div>
            <div class="form-group">
                <label asp-for="DateMiseEnVente" class="control-label"></label>
                <input asp-for="DateMiseEnVente" class="form-control" />
                <span asp-validation-for="DateMiseEnVente" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="PrixMiseEnVente" class="control-label"></label>
                <input asp-for="PrixMiseEnVente" class="form-control" />
                <span asp-validation-for="PrixMiseEnVente" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="AnnoncePubliee" /> @Html.DisplayNameFor(model => model.AnnoncePubliee)
                </label>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="VoitureVendue" /> @Html.DisplayNameFor(model => model.VoitureVendue)
                </label>
            </div>
            <div class="form-group">
                <label asp-for="IdMarque" class="control-label"></label>
                <select asp-for="IdMarque" id="marqueSelect" class="form-control" asp-items="ViewBag.Marques">
                    <option value="">Sélectionnez une marque</option>
                </select>
                <span asp-validation-for="IdMarque" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="IdModele" class="control-label"></label>
                <select asp-for="IdModele" id="modeleSelect" class="form-control" asp-items="ViewBag.Modeles"></select>
                <span asp-validation-for="IdModele" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="IdFinition" class="control-label"></label>
                <select id="finitionSelect" asp-for="IdFinition" class="form-control" asp-items="ViewBag.Finitions"></select>
                <span asp-validation-for="IdFinition" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.addEventListener('DOMContentLoaded', function () {

            const modelesParMarque = @Html.Raw(Json.Serialize(ViewBag.ModelesParMarque));
            const finitionsParModele = @Html.Raw(Json.Serialize(ViewBag.FinitionsParModele));

            const marqueSelect = document.getElementById('marqueSelect');
            const modeleSelect = document.getElementById('modeleSelect');
            const finitionSelect = document.getElementById('finitionSelect');

            // Pré-remplir les modèles si une marque est déjà sélectionnée
            if (marqueSelect.value) {
                let marqueId = marqueSelect.value;
                let listeModeles = modelesParMarque[marqueId];

                modeleSelect.innerHTML = "";
                listeModeles.forEach(m => {
                    modeleSelect.appendChild(new Option(m.text, m.value));
                });

                modeleSelect.disabled = false;
            }

            // Pré-remplir les finitions si un modèle est déjà sélectionné (cas Edit)
            if (modeleSelect.value) {
                let modeleId = modeleSelect.value;
                let listeFinitions = finitionsParModele[modeleId];

                finitionSelect.innerHTML = "";
                listeFinitions.forEach(f => {
                    finitionSelect.appendChild(new Option(f.text, f.value));
                });

                finitionSelect.disabled = false;
            }

            // Gestion des changements
            marqueSelect.addEventListener('change', function () {
                let marqueId = this.value;

                modeleSelect.innerHTML = '<option value="">Sélectionnez un modèle</option>';
                finitionSelect.innerHTML = "";
                finitionSelect.disabled = true;

                if (marqueId) {
                    let listeModeles = modelesParMarque[marqueId];
                    listeModeles.forEach(m => {
                        modeleSelect.appendChild(new Option(m.text, m.value));
                    });
                    modeleSelect.disabled = false;
                } else {
                    modeleSelect.disabled = true;
                }
            });

            modeleSelect.addEventListener('change', function () {
                let modeleId = this.value;

                finitionSelect.innerHTML = '<option value="">Sélectionnez une finition</option>';

                if (modeleId) {
                    let listeFinitions = finitionsParModele[modeleId];
                    listeFinitions.forEach(f => {
                        finitionSelect.appendChild(new Option(f.text, f.value));
                    });
                    finitionSelect.disabled = false;
                } else {
                    finitionSelect.disabled = true;
                }
            });
        });
    </script>
}
