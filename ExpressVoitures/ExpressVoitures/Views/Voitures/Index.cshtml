@model IEnumerable<ExpressVoitures.Models.Voiture>

@{
    ViewData["Title"] = "Liste des voitures";
}

<h1>Listes des voitures</h1>

<p>
    <a asp-action="Create">Créer une nouvelle voiture</a>
</p>

<p>Supprimer une voiture supprimera également les réparations et la vente qui lui sont éventuellement associées.</p>

<table class="table">
    <thead>
        <tr>
            <th>
                Visuel
            </th>
            <th>
                Année
            </th>
            <th>
                Marque
            </th>
            <th>
                Modèle
            </th>
            <th>
                Finition
            </th>
            <th>
                Prix de mise en vente
            </th>
            <th>
                Annonce publiée ?
            </th>
            <th>
                Voiture réparée ?
            </th>
            <th>
                Voiture vendue ?
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @if (!string.IsNullOrEmpty(item.Image))
                {
                    <img src="~/images/voitures/@item.Image"
                            alt="Photo"
                            style="width:100px; height:auto; border-radius:4px;" />
                }
                else
                {
                    <span>Aucune image</span>
                }
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Annee)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Marque.Nom)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Modele.Nom)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Finition.Nom)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.PrixMiseEnVente) €
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.AnnoncePubliee)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.VoitureReparee)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.VoitureVendue)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Editer</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Détails</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Supprimer</a>
            </td>
        </tr>
}
    </tbody>
</table>
