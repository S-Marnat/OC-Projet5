@model ExpressVoitures.Models.Marque

@{
    ViewData["Title"] = "Supprimer une marque";
}

<h1>Supprimer une marque</h1>

<h2>Êtes-vous sûr de vouloir supprimer cette marque ?</h2>
<div>
    <dl class="row">
        <dt class = "col-sm-2">
            Nom de la marque
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Nom)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Supprimer" class="boutonAction  d-flex justify-content-center" /> |
        <a asp-action="Index">Retour à la liste des marques</a>
    </form>
</div>
