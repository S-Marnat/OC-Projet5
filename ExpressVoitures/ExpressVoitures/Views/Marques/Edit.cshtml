@model ExpressVoitures.Models.Marque

@{
    ViewData["Title"] = "Editer une marque";
}

<h1>Editer une marque</h1>

<div class="row formDonnees">
    <div class="col-md-5 mx-auto">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger" aria-live="polite"></div>
            <input type="hidden" asp-for="Id" />
            <div class="form-group">
                <label asp-for="Nom" class="control-label">Nom de la marque</label>
                <input asp-for="Nom" class="form-control" required />
                <span asp-validation-for="Nom" class="text-danger" aria-live="polite"></span>
            </div>
            <div class="form-group d-flex justify-content-center">
                <input type="submit" value="Sauvegarder" class="boutonAction" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Retour à la liste des marques</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
