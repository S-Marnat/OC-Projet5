@model ExpressVoitures.Models.Marque

@{
    ViewData["Title"] = "Créer une nouvelle marque";
}

<h1>Créer une nouvelle marque</h1>

<div class="row formDonnees">
    <div class="col-md-5 mx-auto">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Nom" class="control-label">Nom de la marque</label>
                <input asp-for="Nom" class="form-control" />
                <span asp-validation-for="Nom" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Créer" class="boutonAction" />
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
