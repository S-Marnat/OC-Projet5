@model ExpressVoitures.Models.Reparation

@{
    ViewData["Title"] = "Editer une réparation";
}

<h1>Editer une réparation</h1>

<div class="row formDonnees">
    <div class="col-md-5 mx-auto">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <div class="form-group">
                <label asp-for="ReparationEffectuee" class="control-label">Nom de la réparation</label>
                <input asp-for="ReparationEffectuee" class="form-control" />
                <span asp-validation-for="ReparationEffectuee" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Cout" class="control-label">Prix de la réparation</label>
                <input asp-for="Cout" class="form-control" />
                <span asp-validation-for="Cout" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="IdVoiture" class="control-label">Voiture correspondant à cette réparation</label>
                <select asp-for="IdVoiture" class="form-control" asp-items="ViewBag.IdVoiture"></select>
                <span asp-validation-for="IdVoiture" class="text-danger"></span>
            </div>
            <div class="form-group d-flex justify-content-center">
                <input type="submit" value="Sauvegarder" class="boutonAction" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Retour à la liste des réparations</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
