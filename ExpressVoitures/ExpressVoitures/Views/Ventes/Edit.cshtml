@model ExpressVoitures.Models.Vente

@{
    ViewData["Title"] = "Editer une vente";
}

<h1>Editer une vente</h1>

<div class="row formDonnees">
    <div class="col-md-5 mx-auto">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger" aria-live="polite"></div>
            <input type="hidden" asp-for="Id" />
            <div class="form-group">
                <label asp-for="Date" class="control-label">Date de la vente</label>
                <input asp-for="Date" class="form-control" required />
                <span asp-validation-for="Date" class="text-danger" aria-live="polite"></span>
            </div>
            <div class="form-group">
                <label asp-for="IdVoiture" class="control-label">Voiture correspondant à cette vente</label>
                <select asp-for="IdVoiture" class="form-control" asp-items="ViewBag.IdVoiture" required>
                    <option value="">Sélectionnez une voiture</option>
                </select>
                <span asp-validation-for="IdVoiture" class="text-danger" aria-live="polite"></span>
            </div>
            <div class="form-group d-flex justify-content-center">
                <input type="submit" value="Sauvegarder" class="boutonAction" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Retour à la liste des ventes</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
