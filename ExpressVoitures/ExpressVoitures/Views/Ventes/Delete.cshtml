@model ExpressVoitures.Models.Vente

@{
    ViewData["Title"] = "Supprimer une vente";
}

<h1>Supprimer une vente</h1>

<h2>Êtes-vous sûr de vouloir supprimer cette vente ?</h2>
<div>
    <dl class="row">
        <dt class = "col-sm-2">
            Date de la vente
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Date)
        </dd>
        <dt class = "col-sm-2">
            Voiture correspondant à la vente
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Voiture.CodeVin)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Supprimer" class="boutonAction d-flex justify-content-center" /> |
        <a asp-action="Index">Retour à la liste des ventes</a>
    </form>
</div>
