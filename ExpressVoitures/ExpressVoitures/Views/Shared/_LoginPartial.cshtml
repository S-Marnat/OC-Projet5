@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager
@functions {
    string PageActiveIdentity(string page)
    {
        var currentPage = ViewContext.RouteData.Values["page"]?.ToString();
        return currentPage == page ? "active" : "";
    }
}

<ul class="navbar-nav">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item">
        <form  class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button  type="submit" class="nav-link px-4">Se déconnecter</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
            <a class="nav-link px-4 @PageActiveIdentity("/Account/Authentification")" asp-area="Identity" asp-page="/Account/Authentification">S'authentifier</a>
    </li>
}
</ul>
