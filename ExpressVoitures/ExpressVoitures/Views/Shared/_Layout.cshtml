@functions {
    string PageActive(string controller, string action)
    {
        var currentController = ViewContext.RouteData.Values["controller"] as string;
        var currentAction = ViewContext.RouteData.Values["action"] as string;

        return (currentController == controller && currentAction == action) ? "active" : "";
    }

    string InventaireActif()
    {
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

        // Liste des contrôleurs appartenant à "Inventaire"
        var inventaireControllers = new[] { "Voitures", "Marques", "Modeles", "Finitions", "Reparations", "Ventes" };

        // Inventaire actif uniquement sur les pages Index
        return inventaireControllers.Contains(currentController) && currentAction == "Index" ? "active" : "";
    }
}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Express Voitures</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ExpressVoitures.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm" role="navigation">
            <div class="container-fluid px-5">
                <a class="navbar-brand logo" asp-area="" asp-controller="Home" asp-action="Index">Express Voitures</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link px-4 @PageActive("Home", "Index")" asp-area="" asp-controller="Home" asp-action="Index">Accueil</a>
                        </li>
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link px-4 @PageActive("Voitures", "CreateSimple")" asp-area="" asp-controller="Voitures" asp-action="CreateSimple">Ajouter une voiture</a>
                            </li>
                        }
                        @if (User.IsInRole("Administrateur"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle px-4 @InventaireActif()" href="#" role="button" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                    Inventaire
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item @PageActive("Voitures", "Index")" asp-area="" asp-controller="Voitures" asp-action="Index">Voitures</a></li>
                                    <li><a class="dropdown-item @PageActive("Marques", "Index")" asp-area="" asp-controller="Marques" asp-action="Index">Marques</a></li>
                                    <li><a class="dropdown-item @PageActive("Modeles", "Index")" asp-area="" asp-controller="Modeles" asp-action="Index">Modèles</a></li>
                                    <li><a class="dropdown-item @PageActive("Finitions", "Index")" asp-area="" asp-controller="Finitions" asp-action="Index">Finitions</a></li>
                                    <li><a class="dropdown-item @PageActive("Reparations", "Index")" asp-area="" asp-controller="Reparations" asp-action="Index">Réparations</a></li>
                                    <li><a class="dropdown-item @PageActive("Ventes", "Index")" asp-area="" asp-controller="Ventes" asp-action="Index">Ventes</a></li>
                                </ul>
                            </li>
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
